# Public canonical Worker origin used by browser API clients.
VITE_VWIKI_RACE_API_URL=https://vwikirace-api.example.workers.dev

# Server-only canonical Worker origin for retained same-origin Pages proxies.
VWIKI_RACE_API_URL=https://vwikirace-api.example.workers.dev

# Server-only values for Cloudflare Workers.
# Do not prefix these with VITE_ or expose them to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-cloudflare-secret
ALLOWED_ORIGINS=https://vwikirace.pages.dev
